# Copie para .env e ajuste conforme ambiente local
WMS_POSTGRES_USER=wms
WMS_POSTGRES_PASSWORD=wms
WMS_POSTGRES_DB=wms
WMS_POSTGRES_PORT=5432

# DSN sync (psycopg2) usado pela API/integ. core
WMS_POSTGRES_DSN=postgresql://wms:wms@localhost:5432/wms

# DSN async (SQLAlchemy + asyncpg) usado por Alembic/XML
DATABASE_URL=postgresql+asyncpg://wms:wms@localhost:5432/wms

# API minima (inmemory | postgres)
WMS_API_BACKEND=inmemory
WMS_API_TENANT_ID=loja_demo
WMS_API_LOG_LEVEL=warning
WMS_API_ACCESS_LOG=false
